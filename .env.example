# Ghost Watt - local model configuration. Copy to .env.local and adjust.
# Everything runs on YOUR machine. No external/paid API keys anywhere.

# Where the local Ollama daemon is listening.
OLLAMA_HOST=http://127.0.0.1:11434

# Which local vision model to use for perception.
# 8GB RAM:  moondream        (~1.7GB, fast, CPU-friendly)   <- default
# 12GB+:    qwen2.5vl:3b     (sharper device/state reading)
# 16GB+:    llama3.2-vision  (most capable)
OLLAMA_VISION_MODEL=moondream

# Max time to wait for one image (ms). CPU inference can be slow.
OLLAMA_TIMEOUT_MS=120000
